:set nocompatible
set term=xterm-256color
syntax on
set number
filetype plugin indent on
set tabstop=4
set shiftwidth=4
set expandtab
set encoding=utf-8
set backspace=indent,eol,start
set ttyfast
set ignorecase
set listchars=tab:▸\ ,eol:¬
set t_Co=256
set background=dark
set showmatch
set hlsearch
set autoindent

let g:solarized_termcolors=256
let g:solarized_termtrans=1
colorscheme solarized
"colorscheme darcula
